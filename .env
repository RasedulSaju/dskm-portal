# DSKM Batch Portal - Environment Configuration
# Copy this file to .env and update with your actual values

# Application
APP_ENV=production
APP_DEBUG=false
APP_URL=https://yourdomain.com
APP_KEY=base64:CHANGE_THIS_TO_RANDOM_32_CHARACTER_STRING

# Database
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=dskm_portal
DB_USERNAME=root
DB_PASSWORD=""

# Mail (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@dskmportal.com

# Upload Settings
MAX_UPLOAD_SIZE=5242880
